<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Rezeki App</title>
  <style>
    :root{
      --bg1:#f7f9fe;
      --bg2:#edf2fb;
      --bg3:#e7edf8;
      --card:rgba(255,255,255,.72);
      --card-strong:rgba(255,255,255,.86);
      --stroke:rgba(255,255,255,.78);
      --line:rgba(107,114,128,.14);
      --text:#0f1723;
      --muted:#6a7384;
      --blue:#0a84ff;
      --cyan:#5ac8fa;
      --green:#16a34a;
      --red:#ef4444;
      --gold:#b8891f;
      --shadow:0 28px 80px rgba(25,40,75,.14);
      --shadow-soft:0 12px 30px rgba(25,40,75,.08);
      --radius:30px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 0% 0%,rgba(255,255,255,.95),transparent 28%),
        radial-gradient(circle at 100% 10%,rgba(90,200,250,.18),transparent 26%),
        linear-gradient(180deg,var(--bg1) 0%,var(--bg2) 50%,var(--bg3) 100%);
      min-height:100vh;
    }

    body:before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background:linear-gradient(180deg,rgba(255,255,255,.35),transparent 18%,transparent 82%,rgba(255,255,255,.2));
    }

    .app-shell.locked{
      filter:blur(8px);
      pointer-events:none;
      user-select:none;
    }

    .wrap{
      max-width:440px;
      margin:0 auto;
      padding:12px 16px 130px;
      position:relative;
    }

    .statusbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:8px 6px 18px;
      font-size:14px;
      font-weight:700;
      letter-spacing:.02em;
    }

    .status-icons{
      display:flex;
      gap:8px;
      align-items:center;
      color:var(--text);
    }

    .dot,.sig,.bat{
      display:inline-block;
      border-radius:999px;
    }

    .dot{width:8px;height:8px;background:var(--text);opacity:.86}
    .sig{width:14px;height:10px;border:1.8px solid var(--text);border-top-width:3px;opacity:.75}
    .bat{width:22px;height:11px;border:1.8px solid var(--text);position:relative;opacity:.75}
    .bat:after{
      content:"";
      position:absolute;
      right:-4px;
      top:2px;
      width:2px;
      height:5px;
      background:var(--text);
      border-radius:2px;
    }

    .surface,.hero,.card,.pill,.table-wrap,.form-card,.dock,.mini-stat,.account-item,.tx-item,.doa-card,.slider-card,.chart-card,.pin-card,.pin-modal-card,.action-btn{
      backdrop-filter:blur(24px);
      -webkit-backdrop-filter:blur(24px);
      background:var(--card);
      border:1px solid var(--stroke);
      box-shadow:var(--shadow-soft);
    }

    .hero{
      padding:24px;
      border-radius:36px;
      position:relative;
      overflow:hidden;
      box-shadow:var(--shadow);
    }

    .hero:before{
      content:"";
      position:absolute;
      inset:auto -16% -28% auto;
      width:240px;
      height:240px;
      background:radial-gradient(circle,rgba(10,132,255,.24),transparent 62%);
    }

    .hero:after{
      content:"";
      position:absolute;
      left:-30px;
      top:-55px;
      width:180px;
      height:120px;
      background:radial-gradient(circle,rgba(255,255,255,.85),transparent 70%);
    }

    .topline{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:10px;
      position:relative;
      z-index:1;
      gap:10px;
      flex-wrap:wrap;
    }

    .app-chip,.hero-badge,.section-kicker,.type-badge,.soft-badge,.small-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      border-radius:999px;
      padding:8px 12px;
      font-size:12px;
      font-weight:700;
      letter-spacing:.01em;
    }

    .app-chip{
      background:rgba(255,255,255,.62);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.8);
    }

    .hero-badge{
      background:linear-gradient(135deg,rgba(255,255,255,.92),rgba(255,255,255,.5));
      color:var(--gold);
    }

    .small-badge{
      background:rgba(10,132,255,.10);
      color:var(--blue);
      padding:7px 11px;
    }

    .arabic{
      font-size:24px;
      margin:0 0 10px;
      font-weight:700;
      letter-spacing:.02em;
      position:relative;
      z-index:1;
    }

    .title{
      font-size:31px;
      line-height:1.06;
      margin:0 0 10px;
      font-weight:820;
      letter-spacing:-.04em;
      position:relative;
      z-index:1;
    }

    .sub{
      margin:0;
      color:var(--muted);
      line-height:1.55;
      position:relative;
      z-index:1;
    }

    .pill-row,.stats,.quick,.grid,.section-head,.balance-strip,.action-row,.doa-stack,.chart-summary{
      display:grid;
      gap:12px;
    }

    .pill-row{
      grid-template-columns:repeat(3,1fr);
      margin:18px 0 20px;
      position:relative;
      z-index:1;
    }

    .pill{
      padding:14px 12px;
      border-radius:22px;
      text-align:center;
      background:rgba(255,255,255,.52);
    }

    .pill b,.amount{display:block}
    .pill span,.label,.hint,th,.subtle,.muted{color:var(--muted)}

    .stats{
      grid-template-columns:1fr 1fr;
      margin-top:4px;
      position:relative;
      z-index:1;
    }

    .card,.doa-card,.slider-card,.chart-card{
      padding:18px;
      border-radius:28px;
    }

    .label{
      font-size:12px;
      margin-bottom:8px;
      text-transform:uppercase;
      letter-spacing:.06em;
    }

    .amount{
      font-size:30px;
      font-weight:820;
      letter-spacing:-.05em;
    }

    .hint{
      font-size:13px;
      line-height:1.45;
    }

    .balance-strip{
      grid-template-columns:1.15fr .85fr;
      margin-top:16px;
    }

    .mini-stat{
      padding:16px 18px;
      border-radius:24px;
      background:linear-gradient(180deg,rgba(255,255,255,.78),rgba(255,255,255,.55));
    }

    .mini-stat b{
      display:block;
      font-size:20px;
      letter-spacing:-.03em;
      margin-top:4px;
    }

    .action-row{
      grid-template-columns:1fr 1fr;
      margin-top:14px;
      position:relative;
      z-index:1;
    }

    .action-btn{
      border:none;
      border-radius:20px;
      padding:14px 16px;
      background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,255,255,.58));
      color:var(--text);
      font-weight:760;
      cursor:pointer;
    }

    .section-head{
      grid-template-columns:1fr auto;
      align-items:end;
      margin:26px 4px 12px;
    }

    .section-title{
      font-size:20px;
      font-weight:780;
      margin:0;
      letter-spacing:-.03em;
    }

    .section-kicker{
      background:rgba(255,255,255,.58);
      color:var(--muted);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.8);
    }

    .doa-stack{
      grid-template-columns:1fr;
    }

    .doa-card{
      background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,255,255,.60));
      position:relative;
      overflow:hidden;
      border-radius:32px;
      box-shadow:var(--shadow);
    }

    .doa-card:before{
      content:"";
      position:absolute;
      right:-20px;
      top:-20px;
      width:140px;
      height:140px;
      background:radial-gradient(circle,rgba(90,200,250,.18),transparent 65%);
    }

    .doa-highlight{
      font-size:26px;
      line-height:1.8;
      font-weight:780;
      margin:10px 0 0;
      letter-spacing:.01em;
      position:relative;
      z-index:1;
      white-space:pre-line;
    }

    .doa-caption{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.5;
      position:relative;
      z-index:1;
    }

    .slider-card{
      background:linear-gradient(180deg,rgba(255,255,255,.84),rgba(255,255,255,.58));
      min-height:240px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .hadith-meta{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      margin-bottom:12px;
      flex-wrap:wrap;
    }

    .hadith-title{
      font-size:18px;
      font-weight:780;
      letter-spacing:-.02em;
      margin:0 0 10px;
    }

    .hadith-arabic{
      font-size:20px;
      line-height:1.9;
      margin:0 0 12px;
      font-weight:700;
    }

    .hadith-text{
      margin:0;
      font-size:15px;
      line-height:1.65;
      color:var(--text);
    }

    .slider-footer{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      margin-top:18px;
      flex-wrap:wrap;
    }

    .slider-dots{
      display:flex;
      gap:8px;
      align-items:center;
    }

    .slider-dot{
      width:8px;
      height:8px;
      border-radius:999px;
      background:rgba(15,23,35,.18);
      transition:.25s ease;
    }

    .slider-dot.active{
      width:22px;
      background:linear-gradient(90deg,var(--blue),var(--cyan));
    }

    .slider-nav{
      display:flex;
      gap:8px;
    }

    .nav-btn{
      border:none;
      border-radius:14px;
      padding:10px 14px;
      background:rgba(255,255,255,.82);
      font-weight:760;
      cursor:pointer;
      color:var(--text);
      box-shadow:0 8px 18px rgba(31,41,55,.06);
    }

    .chart-card{
      background:linear-gradient(180deg,rgba(255,255,255,.84),rgba(255,255,255,.58));
    }

    .chart-summary{
      grid-template-columns:1fr 1fr;
      margin-bottom:14px;
    }

    .chart-mini{
      padding:14px 16px;
      border-radius:20px;
      background:rgba(255,255,255,.62);
      border:1px solid rgba(255,255,255,.8);
    }

    .chart-mini b{
      display:block;
      font-size:22px;
      margin-top:4px;
      letter-spacing:-.03em;
    }

    .chart-wrap{
      width:100%;
      height:230px;
      border-radius:24px;
      background:linear-gradient(180deg,rgba(255,255,255,.74),rgba(255,255,255,.48));
      border:1px solid rgba(255,255,255,.78);
      padding:10px;
    }

    canvas{
      width:100%;
      height:100%;
      display:block;
    }

    .form-card,.table-wrap{
      padding:18px;
      border-radius:28px;
      background:linear-gradient(180deg,rgba(255,255,255,.76),rgba(255,255,255,.56));
    }

    .grid.two{
      grid-template-columns:1fr 1fr;
    }

    input,select,textarea,button{
      font:inherit;
    }

    input,select,textarea{
      width:100%;
      border:none;
      outline:none;
      padding:15px 16px;
      border-radius:18px;
      background:rgba(255,255,255,.88);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.9),0 8px 20px rgba(31,41,55,.06);
      color:var(--text);
    }

    textarea{
      min-height:94px;
      resize:vertical;
    }

    .primary-btn{
      border:none;
      border-radius:18px;
      padding:15px 18px;
      background:linear-gradient(135deg,var(--blue),var(--cyan));
      color:#fff;
      font-weight:760;
      box-shadow:0 16px 32px rgba(10,132,255,.28);
      transition:transform .18s ease,box-shadow .18s ease,filter .18s ease;
      cursor:pointer;
    }

    .primary-btn:hover{
      transform:translateY(-1px);
      filter:saturate(1.05);
    }

    .primary-btn:active{
      transform:translateY(1px);
    }

    .secondary-btn{
      border:none;
      border-radius:18px;
      padding:14px 18px;
      background:rgba(255,255,255,.82);
      color:var(--text);
      font-weight:760;
      cursor:pointer;
      box-shadow:0 10px 22px rgba(31,41,55,.06);
    }

    .account-list,.tx-list{
      display:grid;
      gap:10px;
      margin-top:14px;
    }

    .account-item,.tx-item{
      padding:14px 16px;
      border-radius:20px;
      background:linear-gradient(180deg,rgba(255,255,255,.84),rgba(255,255,255,.58));
    }

    .row,.between{
      display:flex;
      align-items:center;
    }

    .between{
      justify-content:space-between;
      gap:12px;
    }

    .row{
      gap:10px;
    }

    .icon-bubble{
      width:40px;
      height:40px;
      border-radius:14px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,rgba(10,132,255,.16),rgba(90,200,250,.24));
      color:var(--blue);
      font-weight:800;
    }

    .acc-name,.tx-title{
      font-weight:760;
      letter-spacing:-.02em;
    }

    .acc-balance{
      font-weight:820;
      letter-spacing:-.03em;
    }

    .soft-badge{
      background:rgba(255,255,255,.72);
      color:var(--muted);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.85);
    }

    .type-badge{
      padding:7px 10px;
    }

    .type-masuk{
      background:rgba(22,163,74,.12);
      color:var(--green);
    }

    .type-keluar{
      background:rgba(239,68,68,.12);
      color:var(--red);
    }

    .footer-note{
      margin-top:16px;
      padding:16px 18px;
      border-radius:22px;
      background:rgba(255,255,255,.52);
      color:var(--muted);
      font-size:13px;
      line-height:1.55;
      border:1px solid rgba(255,255,255,.72);
    }

    .dock{
      position:fixed;
      left:50%;
      bottom:18px;
      transform:translateX(-50%);
      width:min(408px,calc(100% - 28px));
      padding:10px 12px;
      border-radius:28px;
      background:rgba(255,255,255,.72);
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:8px;
      z-index:20;
    }

    .dock-item{
      text-align:center;
      padding:8px 6px;
      border-radius:20px;
      color:var(--muted);
      font-size:11px;
      font-weight:700;
      cursor:pointer;
      border:none;
      background:transparent;
    }

    .dock-item.active{
      background:rgba(10,132,255,.12);
      color:var(--blue);
    }

    .dock-icon{
      display:block;
      font-size:18px;
      margin-bottom:4px;
    }

    .spacer{height:12px}
    .hidden{display:none !important}

    .pin-overlay,.pin-modal{
      position:fixed;
      inset:0;
      background:rgba(239,244,251,.62);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
      z-index:50;
    }

    .pin-card,.pin-modal-card{
      width:min(410px,100%);
      border-radius:32px;
      padding:22px;
      background:linear-gradient(180deg,rgba(255,255,255,.90),rgba(255,255,255,.70));
      box-shadow:var(--shadow);
    }

    .pin-title{
      margin:0 0 8px;
      font-size:28px;
      font-weight:820;
      letter-spacing:-.04em;
    }

    .pin-sub{
      margin:0 0 18px;
      color:var(--muted);
      line-height:1.55;
    }

    .pin-grid{
      display:grid;
      gap:12px;
    }

    .pin-note{
      margin:12px 0 0;
      color:var(--muted);
      font-size:13px;
      line-height:1.5;
    }

    .pin-error{
      margin-top:12px;
      font-size:14px;
      color:var(--red);
      min-height:20px;
    }

    .modal-actions{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:14px;
    }

    .toast{
      position:fixed;
      top:18px;
      left:50%;
      transform:translateX(-50%);
      width:min(420px,calc(100% - 28px));
      background:rgba(15,23,35,.92);
      color:#fff;
      padding:14px 16px;
      border-radius:18px;
      font-size:14px;
      line-height:1.5;
      z-index:60;
      box-shadow:0 20px 40px rgba(15,23,35,.22);
      opacity:0;
      pointer-events:none;
      transition:.25s ease;
    }

    .toast.show{
      opacity:1;
    }

    @media (max-width:380px){
      .pill-row,.stats,.grid.two,.balance-strip,.section-head,.chart-summary,.action-row,.modal-actions{grid-template-columns:1fr}
      .title{font-size:27px}
      .dock{grid-template-columns:repeat(2,1fr)}
      .doa-highlight{font-size:22px}
      .hadith-arabic{font-size:18px}
    }
  </style>
</head>
<body>
  <div id="toast" class="toast"></div>

  <div id="pinOverlay" class="pin-overlay">
    <div class="pin-card">
      <div class="small-badge">🔒 Keamanan aplikasi</div>
      <h2 id="pinTitle" class="pin-title">Masukkan PIN</h2>
      <p id="pinSubtitle" class="pin-sub">Aplikasi ini dikunci dengan PIN agar lebih aman saat dibuka.</p>

      <div class="pin-grid">
        <input id="pinInput" type="password" inputmode="numeric" maxlength="4" placeholder="PIN 4 digit" />
        <input id="pinConfirmInput" class="hidden" type="password" inputmode="numeric" maxlength="4" placeholder="Ulangi PIN 4 digit" />
        <button id="pinSubmitBtn" class="primary-btn">Buka aplikasi</button>
      </div>

      <div id="pinError" class="pin-error"></div>
      <p class="pin-note">Saat pertama kali dipakai, Anda akan diminta membuat PIN dulu. Setelah itu setiap kali file ini dibuka, aplikasi akan meminta PIN tersebut.</p>
    </div>
  </div>

  <div id="pinChangeModal" class="pin-modal hidden">
    <div class="pin-modal-card">
      <div class="small-badge">✦ Ganti PIN</div>
      <h3 class="pin-title" style="font-size:24px;margin-top:10px;">Ubah PIN aplikasi</h3>
      <p class="pin-sub">Masukkan PIN lama lalu buat PIN baru 4 digit.</p>

      <div class="pin-grid">
        <input id="oldPinInput" type="password" inputmode="numeric" maxlength="4" placeholder="PIN lama" />
        <input id="newPinInput" type="password" inputmode="numeric" maxlength="4" placeholder="PIN baru 4 digit" />
        <input id="newPinConfirmInput" type="password" inputmode="numeric" maxlength="4" placeholder="Ulangi PIN baru" />
      </div>

      <div id="changePinError" class="pin-error"></div>

      <div class="modal-actions">
        <button id="cancelPinChange" class="secondary-btn">Batal</button>
        <button id="savePinChange" class="primary-btn">Simpan PIN baru</button>
      </div>
    </div>
  </div>

  <div id="appShell" class="app-shell locked">
    <div class="wrap">
      <div class="statusbar">
        <div id="clockText">9:41</div>
        <div class="status-icons"><span class="dot"></span><span class="sig"></span><span class="bat"></span></div>
      </div>

      <section id="home" class="hero">
        <div class="topline">
          <div class="app-chip">✦ Rezeki App</div>
          <div class="hero-badge">Premium Calm UI</div>
        </div>

        <p class="arabic">من الله مالك الرزق</p>
        <h1 class="title">Kelola uang dengan tenang, jelas, aman, dan terasa premium.</h1>
        <p class="sub">Beranda sudah dirapikan: fokus ke doa utama yang paling menonjol, pengingat hadis shahih yang berganti otomatis, chart saldo sederhana, serta proteksi PIN saat aplikasi dibuka.</p>

        <div class="pill-row">
          <div class="pill"><b>Fokus</b><span>Rezeki tertata</span></div>
          <div class="pill"><b>Mindset</b><span>Syukur + disiplin</span></div>
          <div class="pill"><b>Target</b><span>Saldo makin kuat</span></div>
        </div>

        <div class="stats">
          <div class="card">
            <div class="label">Total saldo keseluruhan</div>
            <div class="amount" id="totalSaldo">Rp 0</div>
            <div class="hint">Akumulasi semua akun digital dan uang cash.</div>
          </div>
          <div class="card">
            <div class="label">Saldo aktif yang dapat dipakai</div>
            <div class="amount" id="saldoAktif">Rp 0</div>
            <div class="hint">Hanya akun di atas Rp 20.000 yang dihitung aktif.</div>
          </div>
        </div>

        <div class="balance-strip">
          <div class="mini-stat"><span class="subtle">Mode keuangan</span><b>Tenang & sadar</b></div>
          <div class="mini-stat"><span class="subtle">Prioritas</span><b>Stabil dulu</b></div>
        </div>

        <div class="action-row">
          <button id="lockAppBtn" class="action-btn">🔒 Kunci aplikasi</button>
          <button id="changePinBtn" class="action-btn">✦ Ganti PIN</button>
        </div>
      </section>

      <div class="section-head">
        <h2 class="section-title">Teks utama paling menonjol</h2>
        <div class="section-kicker">Doa rezeki</div>
      </div>

      <section class="doa-stack">
        <div class="doa-card">
          <div class="small-badge">Paling menonjol</div>
